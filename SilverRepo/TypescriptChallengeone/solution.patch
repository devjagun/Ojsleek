+import { matchPattern } from './helpers';
+
+// @internal
+const matchElementSelections = (
+  element: unknown,
+  pattern: unknown
+): Record<string, unknown[]> | null => {
+  const itemSelections: Record<string, unknown[]> = {};
+  const matched = matchPattern(pattern, element, (key, val) => {
+    itemSelections[key] = (itemSelections[key] || []).concat([val]);
+  });
+  return matched ? itemSelections : null;
+};
+
+// @internal
+const mergeSelections = (
+  accumulator: Record<string, unknown[]>,
+  additions: Record<string, unknown[]>
+): void => {
+  for (const key of Object.keys(additions)) {
+    accumulator[key] = (accumulator[key] || []).concat(additions[key]);
+  }
+};
+
+// @internal
+const ensureRequiredKeys = (
+  selections: Record<string, unknown[]>,
+  requiredKeys: readonly string[]
+): void => {
+  for (const key of requiredKeys) {
+    if (!(key in selections)) {
+      selections[key] = [];
+    }
+  }
+};
+
+// @internal
+export const evaluateArraySome = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+) => {
+  if (!Array.isArray(value) || value.length === 0) return { matched: false };
+
+  const selections: Record<string, unknown[]> = {};
+  let matchedAny = false;
+
+  for (let i = 0; i < value.length; i++) {
+    const itemSelections = matchElementSelections(value[i], pattern);
+    if (itemSelections === null) continue;
+    matchedAny = true;
+    mergeSelections(selections, itemSelections);
+  }
+
+  if (!matchedAny) return { matched: false };
+  ensureRequiredKeys(selections, selectionKeys);
+  return { matched: true, selections };
+};
+
+// @internal
+export const evaluateArrayNone = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+) => {
+  if (!Array.isArray(value)) return { matched: false };
+  for (let i = 0; i < value.length; i++) {
+    if (matchPattern(pattern, value[i], () => {})) return { matched: false };
+  }
+  const selections: Record<string, unknown[]> = {};
+  ensureRequiredKeys(selections, selectionKeys);
+  return { matched: true, selections };
+};
+
+// @internal
+export const evaluateArrayEvery = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+) => {
+  if (!Array.isArray(value)) return { matched: false };
+
+  const selections: Record<string, unknown[]> = {};
+
+  for (let i = 0; i < value.length; i++) {
+    const itemSelections = matchElementSelections(value[i], pattern);
+    if (itemSelections === null) return { matched: false };
+    mergeSelections(selections, itemSelections);
+  }
+
+  ensureRequiredKeys(selections, selectionKeys);
+  return { matched: true, selections };
+};
+
+// @internal
+export const evaluateArrayMinLength = (value: unknown, min: number) => {
+  if (!Array.isArray(value)) return { matched: false };
+  return { matched: value.length >= min };
+};
+
+// @internal
+export const evaluateArrayMaxLength = (value: unknown, max: number) => {
+  if (!Array.isArray(value)) return { matched: false };
+  return { matched: value.length <= max };
+};
+
+// @internal
+export const evaluateArrayLength = (value: unknown, len: number) => {
+  if (!Array.isArray(value)) return { matched: false };
+  return { matched: value.length === len };
+};
+
+// @internal
+export const evaluateArrayEmpty = (value: unknown) => {
+  if (!Array.isArray(value)) return { matched: false };
+  return { matched: value.length === 0 };
+};
+
+// @internal
+export const evaluateArrayNonEmpty = (value: unknown) => {
+  if (!Array.isArray(value)) return { matched: false };
+  return { matched: value.length > 0 };
+};
+
+// @internal
+export const assertNonNegativeInteger = (name: string, value: number) => {
+  if (!Number.isFinite(value) || !Number.isInteger(value) || value < 0) {
+    throw new Error(
+      `\`${name}\` expected a non-negative integer, received ${String(value)}`
+    );
+  }
+};
