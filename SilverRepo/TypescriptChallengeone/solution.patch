+        getSelectionKeys: () => selectionKeys,
+        matcherType: 'arrayNone',
+      };
+    },
+  });
+}
+
+function arrayEvery<
+  input,
+  const pattern extends Pattern<WithDefault<UnwrapArray<input>, unknown>>
+>(pattern: pattern): Chainable<ArrayEveryP<input, pattern>> {
+  const selectionKeys = getSelectionKeys(pattern);
+
+  return chainable({
+    [matcher]() {
+      return {
+        match: (value: any) => evaluateArrayEvery(value, pattern, selectionKeys),
+        getSelectionKeys: () => selectionKeys,
+        matcherType: 'arrayEvery',
+      };
+    },
+  });
+}
+
+function arrayMinLength<input, const min extends number>(
+  min: min
+): Chainable<ArrayMinLengthP<input, min>> {
+  assertNonNegativeInteger('P.array().minLength', min);
+
+  return chainable({
+    [matcher]() {
+      return {
+        match: (value: any) => evaluateArrayMinLength(value, min),
+        matcherType: 'arrayMinLength',
+      };
+    },
+  });
+}
+
+function arrayMaxLength<input, const max extends number>(
+  max: max
+): Chainable<ArrayMaxLengthP<input, max>> {
+  assertNonNegativeInteger('P.array().maxLength', max);
+
+  return chainable({
