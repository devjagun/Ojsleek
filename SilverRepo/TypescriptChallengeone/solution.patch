+function arraySome<
+  input,
+  const pattern extends Pattern<WithDefault<UnwrapArray<input>, unknown>>
+>(pattern: pattern): Chainable<ArraySomeP<input, pattern>> {
+  const selectionKeys = getSelectionKeys(pattern);
