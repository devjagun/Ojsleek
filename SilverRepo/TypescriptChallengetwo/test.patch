+describe('Set and Map quantifier and size chainables', () => {
+  // ---------------------------------------------------------------------------
+  // P.set() quantifiers
+  // ---------------------------------------------------------------------------
+  describe('P.set().some()', () => {
+    it('matches when at least one element matches', () => {
+      const result = match(new Set([1, 'x', 2]))
+        .with(P.set().some(P.string), () => 'hit')
+        .otherwise(() => 'miss');
+
+      expect(result).toBe('hit');
+    });
+
+    it('does not match when no element matches', () => {
+      const result = match(new Set([1, 2, 3]))
+        .with(P.set().some(P.string), () => 'hit')
+        .otherwise(() => 'miss');
+
+      expect(result).toBe('miss');
+    });
+
+    it('does not match empty sets', () => {
+      const result = match(new Set<unknown>())
+        .with(P.set().some(P.string), () => 'hit')
+        .otherwise(() => 'miss');
+
+      expect(result).toBe('miss');
+    });
+
+    it('does not match non-Set inputs', () => {
+      const result = match<unknown, string>([1, 2])
+        .with(P.set().some(P.number), () => 'hit')
+        .otherwise(() => 'miss');
+
+      expect(result).toBe('miss');
+    });
+
+    it('composes with base element subpattern', () => {
+      const yes = match(new Set([1, 2, 3]))
+        .with(P.set(P.number).some(P.number.gt(2)), () => 'hit')
+        .otherwise(() => 'miss');
+
+      const no = match(new Set([1, 2, '3']))
+        .with(P.set(P.number).some(P.number.gt(2)), () => 'hit')
+        .otherwise(() => 'miss');
+
+      expect(yes).toBe('hit');
+      expect(no).toBe('miss');
+    });
+
+    it('select() after some() collects values from matching elements only', () => {
+      const result = match(new Set<number | string>(['a', 10, 'b', 20]))
+        .with(P.set().some(P.number.select('n')), (sel) => sel)
+        .otherwise(() => ({ n: [] as unknown[] }));
+
+      expect(result).toStrictEqual({ n: [10, 20] });
+    });
+  });
+
+  describe('P.set().every()', () => {
+    it('matches when every element matches the subpattern', () => {
+      const result = match(new Set([2, 4, 6]))
+        .with(P.set().every(P.number.positive()), () => 'hit')
+        .otherwise(() => 'miss');
