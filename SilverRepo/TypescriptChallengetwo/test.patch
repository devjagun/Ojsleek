+#!/usr/bin/env bash
+set -euo pipefail
+
+MODE="${1:-new}"
+
+if [ "$MODE" = "base" ]; then
+  npm test -- --runInBand --testPathIgnorePatterns tests/set-map-quantifiers.test.ts
+elif [ "$MODE" = "new" ]; then
+  npm test -- --runInBand tests/set-map-quantifiers.test.ts
+else
+  echo "Usage: $0 [base|new]" >&2
+  exit 1
+fi
