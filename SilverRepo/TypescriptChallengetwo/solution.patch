+import { getSelectionKeys, matchPattern } from './helpers';
+
+export type SelectionLists = Record<string, unknown[]>;
+
+type ItemMatch = {
+  matched: boolean;
+  selections: SelectionLists;
+};
+
+type QuantifierResult = {
+  matched: boolean;
+  selections?: SelectionLists;
+};
+
+const hasOwn = (obj: object, key: string) =>
+  Object.prototype.hasOwnProperty.call(obj, key);
+
+const emptySelections = (): SelectionLists => ({});
+
+const emptySelectionsForKeys = (keys: readonly string[]): SelectionLists => {
+  const selections = emptySelections();
+  for (let i = 0; i < keys.length; i++) {
+    selections[keys[i]] = [];
+  }
+  return selections;
+};
+
+const appendSelectionValue = (
+  target: SelectionLists,
+  key: string,
+  value: unknown
+) => {
+  if (!hasOwn(target, key)) {
+    target[key] = [value];
+    return;
+  }
+  target[key].push(value);
+};
+
+const mergeSelectionLists = (
+  target: SelectionLists,
+  source: SelectionLists
+) => {
+  const keys = Object.keys(source);
+  for (let i = 0; i < keys.length; i++) {
+    const key = keys[i];
+    const values = source[key];
+    if (!hasOwn(target, key)) {
+      target[key] = values.slice();
+      continue;
+    }
+    for (let j = 0; j < values.length; j++) {
+      target[key].push(values[j]);
+    }
+  }
+};
+
+const ensureSelectionKeys = (
+  keys: readonly string[],
+  target: SelectionLists
+) => {
+  for (let i = 0; i < keys.length; i++) {
+    const key = keys[i];
+    if (!hasOwn(target, key)) {
+      target[key] = [];
+    }
+  }
+};
+
+const createSelectionCollector = (target: SelectionLists) => {
+  return (key: string, selected: unknown) => {
+    appendSelectionValue(target, key, selected);
+  };
+};
+
+const matchItemWithSelections = (
+  pattern: unknown,
+  item: unknown
+): ItemMatch => {
+  const selections = emptySelections();
+  const matched = matchPattern(
+    pattern,
+    item,
+    createSelectionCollector(selections)
+  );
+  return { matched, selections };
+};
+
+export const getPatternSelectionKeys = (pattern: unknown): string[] =>
+  getSelectionKeys(pattern);
+
+const isSetInput = (value: unknown): value is Set<unknown> =>
+  value instanceof Set;
+
+const isMapInput = (value: unknown): value is Map<unknown, unknown> =>
+  value instanceof Map;
+
+// ---------------------------------------------------------------------------
+// Set quantifiers
+// ---------------------------------------------------------------------------
+
+export const evaluateSetSome = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isSetInput(value) || value.size === 0) {
+    return { matched: false };
+  }
+
+  const selections = emptySelections();
+  let matchedAny = false;
+
+  for (const item of value) {
+    const itemResult = matchItemWithSelections(pattern, item);
+    if (!itemResult.matched) continue;
+    matchedAny = true;
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  if (!matchedAny) {
+    return { matched: false };
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+export const evaluateSetEvery = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isSetInput(value)) {
+    return { matched: false };
+  }
+
+  const selections = emptySelections();
+
+  for (const item of value) {
+    const itemResult = matchItemWithSelections(pattern, item);
+    if (!itemResult.matched) {
+      return { matched: false };
+    }
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+export const evaluateSetNone = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isSetInput(value)) {
+    return { matched: false };
+  }
+
+  for (const item of value) {
+    if (matchPattern(pattern, item, () => {})) {
+      return { matched: false };
+    }
+  }
+
+  return {
+    matched: true,
+    selections: emptySelectionsForKeys(selectionKeys),
+  };
+};
+
+// ---------------------------------------------------------------------------
+// Set size constraints
+// ---------------------------------------------------------------------------
+
+export const evaluateSetMinSize = (
+  value: unknown,
+  min: number
+): QuantifierResult => {
+  if (!isSetInput(value)) return { matched: false };
+  return { matched: value.size >= min };
+};
+
+export const evaluateSetMaxSize = (
+  value: unknown,
+  max: number
+): QuantifierResult => {
+  if (!isSetInput(value)) return { matched: false };
+  return { matched: value.size <= max };
+};
+
+export const evaluateSetSize = (
+  value: unknown,
+  n: number
+): QuantifierResult => {
+  if (!isSetInput(value)) return { matched: false };
+  return { matched: value.size === n };
+};
+
+export const evaluateSetEmpty = (value: unknown): QuantifierResult => {
+  if (!isSetInput(value)) return { matched: false };
+  return { matched: value.size === 0 };
+};
+
+export const evaluateSetNonEmpty = (value: unknown): QuantifierResult => {
+  if (!isSetInput(value)) return { matched: false };
+  return { matched: value.size > 0 };
+};
+
+// ---------------------------------------------------------------------------
+// Map key quantifiers
+// ---------------------------------------------------------------------------
+
+export const evaluateMapSomeKey = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
