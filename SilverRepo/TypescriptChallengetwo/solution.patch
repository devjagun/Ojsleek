+function setChainable<pattern extends Matcher<any, any, any, any, any>>(
+  pattern: pattern
+): SetChainable<pattern> {
+  return Object.assign(chainable(pattern), {
+    optional: () => setChainable(optional(pattern) as any),
+    select: (key: any) =>
+      setChainable(
+        (key === undefined ? select(pattern) : select(key, pattern)) as any
+      ),
+    some: (p2: any) =>
+      setChainable(intersection(pattern, setSomeMatcher(p2)) as any),
+    every: (p2: any) =>
+      setChainable(intersection(pattern, setEveryMatcher(p2)) as any),
+    none: (p2: any) =>
+      setChainable(intersection(pattern, setNoneMatcher(p2)) as any),
+    minSize: (min: number) =>
+      setChainable(intersection(pattern, setMinSizeMatcher(min)) as any),
+    maxSize: (max: number) =>
+      setChainable(intersection(pattern, setMaxSizeMatcher(max)) as any),
+    size: (n: number) =>
+      setChainable(intersection(pattern, setSizeMatcher(n)) as any),
+    empty: () =>
+      setChainable(intersection(pattern, setEmptyMatcher()) as any),
+    nonEmpty: () =>
+      setChainable(intersection(pattern, setNonEmptyMatcher()) as any),
+  }) as any;
+}
+
