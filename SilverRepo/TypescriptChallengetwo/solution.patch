+    const itemResult = matchItemWithSelections(pattern, key);
+    if (!itemResult.matched) continue;
+    matchedAny = true;
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  if (!matchedAny) {
+    return { matched: false };
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+export const evaluateMapEveryKey = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isMapInput(value)) {
+    return { matched: false };
+  }
+
+  const selections = emptySelections();
+
+  for (const key of value.keys()) {
+    const itemResult = matchItemWithSelections(pattern, key);
+    if (!itemResult.matched) {
+      return { matched: false };
+    }
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+export const evaluateMapNoneKey = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isMapInput(value)) {
+    return { matched: false };
+  }
+
+  for (const key of value.keys()) {
+    if (matchPattern(pattern, key, () => {})) {
+      return { matched: false };
+    }
+  }
+
+  return {
+    matched: true,
+    selections: emptySelectionsForKeys(selectionKeys),
+  };
+};
+
+// ---------------------------------------------------------------------------
+// Map value quantifiers
+// ---------------------------------------------------------------------------
+
+export const evaluateMapSomeValue = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isMapInput(value) || value.size === 0) {
+    return { matched: false };
+  }
+
+  const selections = emptySelections();
+  let matchedAny = false;
+
+  for (const val of value.values()) {
+    const itemResult = matchItemWithSelections(pattern, val);
+    if (!itemResult.matched) continue;
+    matchedAny = true;
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  if (!matchedAny) {
+    return { matched: false };
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+export const evaluateMapEveryValue = (
+  value: unknown,
+  pattern: unknown,
+  selectionKeys: readonly string[]
+): QuantifierResult => {
+  if (!isMapInput(value)) {
+    return { matched: false };
+  }
+
+  const selections = emptySelections();
+
+  for (const val of value.values()) {
+    const itemResult = matchItemWithSelections(pattern, val);
+    if (!itemResult.matched) {
+      return { matched: false };
+    }
+    mergeSelectionLists(selections, itemResult.selections);
+  }
+
+  ensureSelectionKeys(selectionKeys, selections);
+  return { matched: true, selections };
+};
+
+// ---------------------------------------------------------------------------
+// Map size constraints
+// ---------------------------------------------------------------------------
+
+export const evaluateMapMinSize = (
+  value: unknown,
+  min: number
+): QuantifierResult => {
+  if (!isMapInput(value)) return { matched: false };
+  return { matched: value.size >= min };
+};
+
+export const evaluateMapMaxSize = (
+  value: unknown,
+  max: number
+): QuantifierResult => {
+  if (!isMapInput(value)) return { matched: false };
+  return { matched: value.size <= max };
+};
+
+export const evaluateMapSize = (
+  value: unknown,
+  n: number
+): QuantifierResult => {
+  if (!isMapInput(value)) return { matched: false };
+  return { matched: value.size === n };
+};
+
+export const evaluateMapEmpty = (value: unknown): QuantifierResult => {
+  if (!isMapInput(value)) return { matched: false };
+  return { matched: value.size === 0 };
+};
+
+export const evaluateMapNonEmpty = (value: unknown): QuantifierResult => {
+  if (!isMapInput(value)) return { matched: false };
+  return { matched: value.size > 0 };
+};
+
+// ---------------------------------------------------------------------------
+// Bounds validation
+// ---------------------------------------------------------------------------
+
+export const assertNonNegativeInteger = (
+  methodName: string,
+  value: number
+): void => {
+  if (!Number.isInteger(value) || value < 0) {
+    throw new Error(
+      `\`${methodName}\` expected a non-negative integer, received ${value}`
+    );
+  }
+};
